{
  "id": "compliance-agent",
  "orchestratorTask": "compliance-review",
  "orchestratorStatePath": "../../orchestrator/data/orchestrator-state.json",
  "serviceStatePath": "../../logs/compliance-agent-service.json",
  "name": "Compliance Agent",
  "description": "Synthesizes bounded compliance posture across local policy documents, dependency manifests, and release-facing governance evidence.",
  "version": "1.0.0",
  "model": {
    "primary": "claude-3-5-sonnet",
    "fallback": "gpt-4o-mini",
    "tier": "balanced",
    "temperature": 0.2,
    "maxTokens": 2048
  },
  "maxConcurrentTasks": 2,
  "permissions": {
    "skills": {
      "runtimeStateReader": {
        "allowed": true,
        "maxCalls": 20,
        "reason": "Read bounded runtime-state governance evidence."
      },
      "repoFileReader": {
        "allowed": true,
        "maxCalls": 60,
        "reason": "Read bounded local policy, manifest, and lockfile evidence."
      }
    },
    "fileSystem": {
      "readPaths": [
        "../../package.json",
        "../../orchestrator/package.json",
        "../../operator-s-console/package.json",
        "../../package-lock.json",
        "../../pnpm-lock.yaml",
        "../../yarn.lock",
        "../../orchestrator/package-lock.json",
        "../../operator-s-console/package-lock.json",
        "../../LICENSE",
        "../../SECURITY.md",
        "../../CODE_OF_CONDUCT.md",
        "../../CONTRIBUTING.md",
        "../../README.md",
        "../../docs/operations/public-release.md",
        "../../docs/operations/deployment.md",
        "../../docs/operations/backup-recovery.md"
      ]
    },
    "network": {
      "allowed": false
    }
  },
  "constraints": {
    "timeoutSec": 90,
    "maxRetries": 1
  }
}
