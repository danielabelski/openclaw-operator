{
  "id": "code-index-agent",
  "orchestratorTask": "code-index",
  "orchestratorStatePath": "../../orchestrator/data/orchestrator-state.json",
  "serviceStatePath": "../../logs/code-index-agent-service.json",
  "knowledgePackDir": "../../logs/knowledge-packs",
  "name": "Code Index Agent",
  "description": "Synthesizes bounded code-index posture across repo coverage, doc-to-code linkage, search gaps, and retrieval freshness.",
  "version": "1.0.0",
  "model": {
    "primary": "claude-3-5-sonnet",
    "fallback": "gpt-4o-mini",
    "tier": "balanced",
    "temperature": 0.2,
    "maxTokens": 2048
  },
  "maxConcurrentTasks": 2,
  "permissions": {
    "skills": {
      "runtimeStateReader": {
        "allowed": true,
        "maxCalls": 20,
        "reason": "Read bounded runtime-state freshness and repair evidence."
      },
      "repoFileReader": {
        "allowed": true,
        "maxCalls": 80,
        "reason": "Read bounded local repo, docs, and code surfaces for index posture."
      },
      "knowledgePackReader": {
        "allowed": true,
        "maxCalls": 20,
        "reason": "Read bounded knowledge-pack artifacts for retrieval freshness and contradiction posture."
      },
      "coding_audit": { "allowed": true },
      "coding_repo_map": { "allowed": true },
      "coding_route_trace": { "allowed": true },
      "coding_env_audit": { "allowed": true },
      "coding_secret_audit": { "allowed": true },
      "coding_api_contract_audit": { "allowed": true },
      "coding_migration_review": { "allowed": true },
      "coding_github_handoff": { "allowed": true },
      "coding_deployment_preflight": { "allowed": true },
      "coding_validate_project": { "allowed": true },
      "coding_validate_adapters": { "allowed": true },
      "coding_validate_pack": { "allowed": true }
    },
    "fileSystem": {
      "readPaths": [
        "../../orchestrator/data/orchestrator-state.json",
        "../../docs",
        "../../site/docs",
        "../../orchestrator/src",
        "../../operator-s-console/src",
        "../../agents",
        "../../README.md",
        "../../QUICKSTART.md",
        "../../DEPLOYMENT.md",
        "../../WORKBOARD.md",
        "../../logs/knowledge-packs"
      ]
    },
    "network": {
      "allowed": false
    }
  },
  "constraints": {
    "timeoutSec": 90,
    "maxRetries": 1
  }
}
