{
  "id": "release-manager-agent",
  "orchestratorTask": "release-readiness",
  "orchestratorStatePath": "../../orchestrator/data/orchestrator-state.json",
  "serviceStatePath": "../../logs/release-manager-agent-service.json",
  "name": "Release Manager Agent",
  "description": "Synthesizes release posture across verification, security, system health, and governed build evidence.",
  "version": "1.0.0",
  "model": {
    "primary": "claude-3-5-sonnet",
    "fallback": "gpt-4o-mini",
    "tier": "balanced",
    "temperature": 0.2,
    "maxTokens": 2048
  },
  "maxConcurrentTasks": 2,
  "permissions": {
    "skills": {
      "runtimeStateReader": {
        "allowed": true,
        "maxCalls": 40,
        "reason": "Read bounded runtime-state evidence for release posture."
      }
    },
    "fileSystem": {
      "readPaths": [
        "../../orchestrator/data/orchestrator-state.json"
      ]
    },
    "network": {
      "allowed": false
    }
  },
  "constraints": {
    "timeoutSec": 90,
    "maxRetries": 1
  }
}
