{
  "id": "deployment-ops-agent",
  "orchestratorTask": "deployment-ops",
  "orchestratorStatePath": "../../orchestrator/data/orchestrator-state.json",
  "serviceStatePath": "../../logs/deployment-ops-agent-service.json",
  "name": "Deployment Ops Agent",
  "description": "Synthesizes bounded deployment posture across rollout surfaces, rollback readiness, pipeline evidence, and docs parity.",
  "version": "1.0.0",
  "model": {
    "primary": "claude-3-5-sonnet",
    "fallback": "gpt-4o-mini",
    "tier": "balanced",
    "temperature": 0.2,
    "maxTokens": 2048
  },
  "maxConcurrentTasks": 2,
  "permissions": {
    "skills": {
      "runtimeStateReader": {
        "allowed": true,
        "maxCalls": 20,
        "reason": "Read bounded runtime-state evidence for deployment posture."
      },
      "repoFileReader": {
        "allowed": true,
        "maxCalls": 60,
        "reason": "Read bounded deployment files, workflow definitions, and docs parity surfaces."
      }
    },
    "fileSystem": {
      "readPaths": [
        "../../orchestrator/data/orchestrator-state.json",
        "../../systemd/orchestrator.service",
        "../../docker-compose.yml",
        "../../Dockerfile",
        "../../.github/workflows/deploy.yml",
        "../../.github/workflows/docker-demo-smoke.yml",
        "../../DEPLOYMENT.md",
        "../../docs/operations/deployment.md",
        "../../QUICKSTART.md",
        "../../docs/start/quickstart.md"
      ]
    },
    "network": {
      "allowed": false
    }
  },
  "constraints": {
    "timeoutSec": 90,
    "maxRetries": 1
  }
}
