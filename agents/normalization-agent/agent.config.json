{
  "id": "normalization-agent",
  "orchestratorTask": "normalize-data",
  "orchestratorStatePath": "mongo:orchestrator-runtime-state",
  "serviceStatePath": "../../logs/normalization-agent-service.json",
  "name": "Data Normalization Agent",
  "description": "Transforms raw data into standardized formats: schema mapping, type conversion, deduplication, validation",
  "model": {
    "primary": "gpt-4o-mini",
    "fallback": "gpt-4o-mini",
    "tier": "cheap",
    "temperature": 0.2,
    "maxTokens": 2048
  },
  "maxConcurrentTasks": 20,
  "permissions": {
    "skills": {
      "normalizer": { "allowed": true, "maxCalls": 100, "reason": "Data normalization" },
      "documentParser": { "allowed": true, "maxCalls": 50, "reason": "Parse input data" }
    },
    "network": { "allowed": false }
  },
  "constraints": { "timeoutSec": 120, "maxRetries": 1 },
  "heartbeat": { "interval": "5m", "checks": ["skill_access", "performance"] }
}
