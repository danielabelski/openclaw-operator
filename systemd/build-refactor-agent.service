# service-mode implementation present; direct service execution remains gated
[Unit]
Description=OpenClaw Build Refactor Agent Service
ConditionPathExists=%h/openclaw-operator/agents/build-refactor-agent/src/service.ts
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/openclaw-operator/agents/build-refactor-agent
Environment=ALLOW_DIRECT_SERVICE=true
ExecStart=/usr/bin/env bash -lc 'exec node ../../node_modules/tsx/dist/cli.mjs src/service.ts'
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
