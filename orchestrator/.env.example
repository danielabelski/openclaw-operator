# OpenClaw Operator local-first environment template
# Copy to orchestrator/.env for repo-native local development.
# This file is intentionally minimal for Path A:
# - local runtime state persists to ./orchestrator/data/orchestrator-state.json
# - Mongo is optional for historical persistence and exports
# - Redis is optional for shared coordination and response caching

# Required auth
API_KEY_ROTATION=[{"key":"CHANGE_ME_VIEWER_KEY","label":"viewer-key","roles":["viewer"],"expiresAt":"2030-01-01T00:00:00.000Z"},{"key":"CHANGE_ME_OPERATOR_KEY","label":"operator-key","roles":["operator"],"expiresAt":"2030-01-01T00:00:00.000Z"},{"key":"CHANGE_ME_ADMIN_KEY","label":"admin-key","roles":["admin"],"expiresAt":"2030-01-01T00:00:00.000Z"}]
API_KEY=CHANGE_ME_FALLBACK_KEY
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# Usually required for the common agent mix
OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
ANTHROPIC_API_KEY=

# Local runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Optional Mongo historical persistence
# Leave DATABASE_URL empty to keep first-run local dev file-backed only.
DATABASE_URL=
DB_NAME=orchestrator
MONGO_USERNAME=
MONGO_PASSWORD=

# Optional Redis coordination/cache
# Leave REDIS_URL empty to use in-memory coordination and response cache.
REDIS_URL=
REDIS_PASSWORD=

# Optional alerting / integrations
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@example.com
ALERT_EMAIL=
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts
MILESTONE_SIGNING_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_SUBREDDIT=openclawdbot_dev
REDDIT_WIKI_PAGE=milestones-feed

# Optional local preview origins
ORCHESTRATOR_CORS_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
